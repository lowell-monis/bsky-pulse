# ─── Storage backend ───────────────────────────────────────────────────────────
# Set STORAGE_BACKEND to "json" (default) or "mongodb"
STORAGE_BACKEND=json

# Path for local JSON storage (used when STORAGE_BACKEND=json)
JSON_PATH=data/posts.json

# ─── MongoDB / Atlas credentials (used when STORAGE_BACKEND=mongodb) ──────────
# Connection URI for MongoDB Atlas (X.509 auth example shown below)
MONGO_URI=mongodb+srv://sentiment.nccvqmg.mongodb.net/?authSource=%24external&authMechanism=MONGODB-X509&appName=sentiment

# Absolute path to your X.509 client certificate/key file (.pem)
CERT_FILE_PATH=/path/to/your/client-cert.pem

# ─── Migration: local MongoDB → Atlas ─────────────────────────────────────────
# URI for the LOCAL MongoDB instance (used by migrate.py)
LOCAL_MONGO_URI=mongodb://localhost:27017

# URI for the destination Atlas cluster (used by migrate.py)
CLUSTER_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/

# ─── Jetstream / firehose ─────────────────────────────────────────────────────
JETSTREAM_URI=wss://jetstream2.us-east.bsky.network/subscribe?wantedCollections=app.bsky.feed.post

# ─── Tuning ───────────────────────────────────────────────────────────────────
# Number of heavy-hitter keyword candidates tracked by Misra-Gries (collect.py)
MG_K=50
